#bai 5
numbers = list(map(float, input("Nhập danh sách số thực (cách nhau bởi dấu cách): ").split()))
for i in range(1, len(numbers)):
    key = numbers[i]
    j = i - 1
    while j >= 0 and numbers[j] < key:
        numbers[j + 1] = numbers[j]
        j -= 1
    numbers[j + 1] = key
print("Danh sách sau khi sắp xếp giảm dần:", numbers)
#bai 6
numbers = list(map(int, input("Nhập số nguyên: ").split()))
n = len(numbers)
swap_count = 0
for i in range(n):
    for j in range(0, n - i - 1):
        if numbers[j] > numbers[j + 1]:
            numbers[j], numbers[j + 1] = numbers[j + 1], numbers[j]
            swap_count += 1
print("Danh sách khi sắp xếp:", numbers)
print("Số lần hoán đổi:", swap_count)
