#bai 14
def count_vowels(s):
    vowels = "aeiou"
    count = 0
    for char in s.lower():
        if char in vowels:
            count += 1
    return count
text = input("Nhập chuỗi: ")
print("Số nguyên âm:", count_vowels(text))
