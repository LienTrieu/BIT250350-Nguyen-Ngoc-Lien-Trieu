class Student:
    def __init__(self, name, score):
        self.name = name
        if 0 <= score <= 10:
            self.score = score
        else:
            self.score = 0
    def display(self):
        print(f"Sinh viên {self.name} có điểm là {self.score}")
sv1 = Student("A", 10)
sv2 = Student("B", 8)
sv1.display()
sv2.display()
#cau 10
def add_product():
    code = input("Nhập mã sản phẩm: ")
    name = input("Nhập tên sản phẩm: ")
    price = input("Nhập giá: ")
    f = open("products.txt", "a", encoding="utf-8")
    f.write(code + ";" + name + ";" + price + "\n")
    f.close()
    print("Đã thêm sản phẩm!")
def show_products():
    f = open("products.txt", "r", encoding="utf-8")
    print("Danh sách sản phẩm:")
    for line in f:
        data = line.strip().split(";")
        print("Code:", data[0], "| Name:", data[1], "| Price:", data[2])
    f.close()
def sort_products():
    products = []
    f = open("products.txt", "r", encoding="utf-8")
    for line in f:
        data = line.strip().split(";")
        code = data[0]
        name = data[1]
        price = float(data[2])
        products.append([code, name, price])
    f.close()
    products.sort(key=lambda x: x[2], reverse=True)
    print("Danh sách sau khi sắp xếp (giá giảm dần):")
    for p in products:
        print(p[0], p[1], p[2])
while True:
    choice = input("Chọn chức năng: ")
    if choice == "1":
        add_product()
    elif choice == "2":
        show_products()
    elif choice == "3":
        sort_products()
    elif choice == "4":
        break
    else:
        print("Lựa chọn không hợp lệ")
